{
  "name": "pi-never-dies",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal production-ready Telegram orchestrator using Cursor SDK and A2A cards.",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@cursor/sdk": "latest",
    "telegraf": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
